Перем _АдресИзКоробки;

// Возвращает адрес сервера, прочитанный из коробки с детальками на этапе инициализации поделки.
//
//  Возвращаемое значение:
//   Строка, Неопределено - адрес сервера либо Неопределено, если коробка не была прочитана.
//
Функция АдресИзКоробки() Экспорт
	Возврат _АдресИзКоробки;
КонецФункции

Процедура ПриИнициализацииПоделки(Поделка) Экспорт

	Коробка = Поделка.НайтиЖелудь("ПараметрыЗаготовки");
	_АдресИзКоробки = Коробка.АдресСервера;

КонецПроцедуры

&Заготовка
Процедура ПриСозданииОбъекта()
КонецПроцедуры
