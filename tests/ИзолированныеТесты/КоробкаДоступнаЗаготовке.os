#Использовать asserts
// Библиотеки подключаются раньше самой осени и в порядке "сначала заготовка, потом коробка",
// чтобы типы заготовки зарегистрировались в движке раньше типов коробки с детальками.
// Так проверяется, что порядок регистрации жителей леса не зависит от порядка загрузки типов.
#Использовать "../ЗаготовкаСКоробкой"
#Использовать "../КоробкаДляЗаготовки"
#Использовать "../../src"

Перем _СтарыйТекущийКаталог;

Процедура ПередЗапускомТеста() Экспорт
	_СтарыйТекущийКаталог = ТекущийКаталог();
КонецПроцедуры

Процедура ПослеЗапускаТеста() Экспорт
	УстановитьТекущийКаталог(_СтарыйТекущийКаталог);
КонецПроцедуры

// Заготовка создается сразу же в момент ее регистрации, поэтому коробки с детальками
// должны быть зарегистрированы и заполнены раньше заготовок.
&Тест
Процедура ЗаготовкаВидитЗаполненнуюКоробку() Экспорт

	// Дано
	ПараметрыЗаготовки = Новый Соответствие;
	ПараметрыЗаготовки.Вставить("АдресСервера", "server-из-конфига");

	КаталогНастроек = СоздатьКонфигВоВременномКаталоге(ПараметрыЗаготовки, "ПараметрыЗаготовки");
	УстановитьТекущийКаталог(КаталогНастроек);

	// Когда
	Поделка = Новый Поделка();
	Заготовка = Поделка.НайтиЖелудь("ЗаготовкаЧитающаяКоробку");

	// Тогда
	Ожидаем.Что(Заготовка.АдресИзКоробки(), "Адрес, прочитанный заготовкой из коробки")
		.Равно("server-из-конфига");

КонецПроцедуры

Функция СоздатьКонфигВоВременномКаталоге(ДанныеПрефикса, Префикс)

	Данные = Новый Соответствие;
	Данные.Вставить(Префикс, ДанныеПрефикса);

	КаталогВременный = ПолучитьИмяВременногоФайла();
	СоздатьКаталог(КаталогВременный);

	ИмяФайла = ОбъединитьПути(КаталогВременный, "autumn-properties.json");
	Запись = Новый ЗаписьJSON();
	Запись.ОткрытьФайл(ИмяФайла);
	ЗаписатьJSON(Запись, Данные);
	Запись.Закрыть();

	Возврат КаталогВременный;

КонецФункции
